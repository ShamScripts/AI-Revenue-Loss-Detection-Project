# Normalize line endings for cross-platform GitHub collaboration
* text=auto eol=lf

# Windows scripts
*.bat text eol=crlf
# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.woff2 binary
*.csv filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
*.joblib filter=lfs diff=lfs merge=lfs -text
